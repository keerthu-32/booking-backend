# App
NODE_ENV=development
PORT=5000
API_VERSION=v1
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/flight_booking

# JWT
JWT_ACCESS_SECRET=dev_access_secret_key_12345
JWT_REFRESH_SECRET=dev_refresh_secret_key_12345
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Payment - Stripe
STRIPE_SECRET_KEY=sk_test_51234567890
STRIPE_PUBLISHABLE_KEY=pk_test_0987654321
STRIPE_WEBHOOK_SECRET=whsec_test_123456

# Email
SENDGRID_API_KEY=test_sendgrid_key
EMAIL_FROM=noreply@flightapp.com

# Airline API - Amadeus
AMADEUS_CLIENT_ID=test_amadeus_id
AMADEUS_CLIENT_SECRET=test_amadeus_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Security
BCRYPT_SALT_ROUNDS=12
